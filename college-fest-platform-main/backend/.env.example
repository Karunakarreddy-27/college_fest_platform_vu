# Environment Configuration
PORT=5000

# MongoDB Configuration (Choose one option)

# Option 1: Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/college-fest

# Option 2: MongoDB Atlas (Cloud Database)
# Get your free cluster from: https://www.mongodb.com/cloud/atlas/register
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/college-fest?retryWrites=true&w=majority&appName=college-fest

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Node Environment
NODE_ENV=development

# Auto seed default events on startup when DB has no active events.
# Defaults to true in production and false in development when unset.
# AUTO_SEED_EVENTS=true

# Frontend URL for CORS and reset links (Vercel domain in production)
FRONTEND_URL=http://localhost:3000

# Manual QR Payment Configuration
MANUAL_PAYMENT_UPI_ID=collegefest@upi
MANUAL_PAYMENT_PAYEE_NAME=College Fest
